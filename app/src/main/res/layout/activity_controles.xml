<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".Controles">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="2dp"
        android:fitsSystemWindows="true">


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONTROLES DE USUARIO BÁSICOS"
            android:gravity="center"
            android:textSize="24sp"
            android:fontFamily="@font/font_login"
            android:layout_marginBottom="20dp"
            android:textColor="@android:color/black"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nivel:"
            android:textSize="16sp"
            android:fontFamily="@font/font_login"
            android:layout_marginBottom="8dp"/>

        <SeekBar
            android:id="@+id/sbNivel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:layout_marginBottom="20dp"/>


        <CheckBox
            android:id="@+id/abAceptar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aceptar"
            android:textSize="16sp"
            android:fontFamily="@font/font_login"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sexo:"
            android:textSize="16sp"
            android:fontFamily="@font/font_login"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rbSexo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbM"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masculino"
                android:textSize="16sp"
                android:fontFamily="@font/font_login"/>

            <RadioButton
                android:id="@+id/rbF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Femenino"
                android:textSize="16sp"
                android:fontFamily="@font/font_login"/>

        </RadioGroup>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado:"
            android:textSize="16sp"
            android:fontFamily="@font/font_login"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="8dp"/>

        <ToggleButton
            android:id="@+id/tbInterruptor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textOn="ACTIVO"
            android:textOff="INACTIVO"
            android:textSize="14sp"/>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha:"
            android:textSize="16sp"
            android:fontFamily="@font/font_login"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="8dp"/>

        <CalendarView
            android:id="@+id/cvFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:firstDayOfWeek="2"/>

        <!-- 🔹 ProgressBar -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Progreso:"
            android:textSize="16sp"
            android:fontFamily="@font/font_login"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/pbCarga"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="30"/>

        <!-- 🔹 RatingBar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calificación:"
            android:textSize="16sp"
            android:fontFamily="@font/font_login"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="8dp"/>

        <RatingBar
            android:id="@+id/rbCalificacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="10"
            android:rating="3.5"
            android:stepSize="0.5"
            android:layout_gravity="center"/>

        <!-- 🔹 ImageView -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto:"
            android:textSize="16sp"
            android:fontFamily="@font/font_login"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:id="@+id/imFoto"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/login_usuario"
            android:scaleType="centerCrop"
            android:layout_gravity="center"
            />

        <!-- 🔹 Botón Envío -->
        <Button
            android:id="@+id/btnEnvio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="Enviar"
            android:textSize="18sp"
            android:padding="12dp"/>

    </LinearLayout>
</ScrollView>