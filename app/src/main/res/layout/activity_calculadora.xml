<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/back"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- TÍTULO CON ESTILO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ecuación Cuadrática"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/font_login"
            android:letterSpacing="0.05"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Juan Manuel Medina Garcia, Grupo:803"
            android:fontFamily="@font/font_login"
            android:textColor="@android:color/secondary_text_light_nodisable"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculadora de raíces"
            android:textSize="14sp"
            android:textColor="#B0B0B0"
            android:fontFamily="@font/font_login"
            android:layout_marginBottom="32dp"/>

        <!-- CARD DE INPUTS (Fondo Blanco para contraste) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Fórmula Destacada -->

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ax² + bx + c = 0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:fontFamily="@font/font_login"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"
                    android:background="#F5F7FA"
                    android:padding="12dp"
                    app:cornerRadius="12dp"/>
                <!-- Fórmula Destacada (CON ID AGREGADO) -->
                <TextView
                    android:id="@+id/tvFormula"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ax² + bx + c = 0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:fontFamily="@font/font_login"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"
                    android:background="#F5F7FA"
                    android:padding="12dp"
                    app:cornerRadius="12dp"/>

                <!-- INPUT A -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Coeficiente a"
                    app:boxStrokeColor="#3F51B5"
                    app:hintTextColor="#3F51B5">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etA"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font_login"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#333333"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- INPUT B -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Coeficiente b"
                    android:layout_marginTop="16dp"
                    app:boxStrokeColor="#3F51B5"
                    app:hintTextColor="#3F51B5">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etB"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font_login"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#333333"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- INPUT C -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Coeficiente c"
                    android:layout_marginTop="16dp"
                    app:boxStrokeColor="#3F51B5"
                    app:hintTextColor="#3F51B5">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etC"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font_login"
                        android:inputType="numberDecimal|numberSigned"
                        android:textColor="#333333"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- BOTÓN DE ACCIÓN PRINCIPAL -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResolver"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="CALCULAR RAÍCES"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/font_login"
                    android:layout_marginTop="32dp"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#3F51B5"
                    app:elevation="6dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD DE RESULTADO  -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1E1E1E">

            <TextView
                android:id="@+id/tvResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El resultado aparecerá aquí"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/font_login"
                android:padding="24dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"/>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>